# =============================================================================
# ManuControl — variáveis de ambiente
# Copie este arquivo para .env na raiz do projeto e ajuste os valores.
# =============================================================================

# Obrigatório em produção: chave aleatória longa (sessões Flask)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-em-producao

# Caminho do banco SQLite (recomendado: pasta persistente fora do deploy)
# Linux:  /var/lib/manucontrol/manu.db
# Windows: D:\apps\manucontrol\data\manu.db
# DATABASE_PATH=/var/lib/manucontrol/manu.db

# Servidor embutido (somente desenvolvimento)
# FLASK_DEBUG=false
# PORT=5000

# Gunicorn (Linux) — workers sugeridos: 2 × CPUs + 1
# GUNICORN_BIND=127.0.0.1:8000
# GUNICORN_WORKERS=3
